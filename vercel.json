{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm -w run typecheck:libs && BASE_PATH=/ PORT=3000 NODE_ENV=production pnpm --filter @workspace/basketball-app run build && pnpm --filter @workspace/api-server run build",
  "outputDirectory": "artifacts/basketball-app/dist/public",
  "framework": null,
  "functions": {
    "api/server.js": {
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/server.js" },
    { "src": "/(.*\\.(js|css|svg|png|ico|txt|map|woff2?))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
